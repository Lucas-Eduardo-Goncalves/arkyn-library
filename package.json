{
	"name": "arkyn",
	"description": "A comprehensive TypeScript ecosystem for building modern web applications with React and Remix, featuring UI components, server utilities, shared tools, and data templates.",
	"version": "1.0.0",
	"author": "Arkyn | Lucas Gonçalves",
	"license": "Apache-2.0",
	"keywords": [
		"react",
		"remix",
		"typescript",
		"ui-components",
		"server-utilities",
		"validation",
		"formatting",
		"monorepo"
	],
	"devDependencies": {
		"@arkyn/components": "workspace:*",
		"@arkyn/server": "workspace:*",
		"@arkyn/shared": "workspace:*",
		"@arkyn/templates": "workspace:*",
		"@biomejs/biome": "catalog:"
	},
	"catalog": {
		"@biomejs/biome": "^2.5.1",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.0.1",
		"libphonenumber-js": "^1.13.7",
		"vite": "^8.1.0",
		"vitest": "^4.1.9"
	},
	"scripts": {
		"all:audit": "bun run components:audit && bun run server:audit && bun run shared:audit && bun run templates:audit",
		"all:build": "bun run templates:build && bun run shared:build && bun run components:build && bun run server:build",
		"all:publish:beta": "bun run components:publish:beta && bun run server:publish:beta && bun run shared:publish:beta && bun run templates:publish:beta",
		"all:release:beta": "bun run components:release:beta && bun run server:release:beta && bun run shared:release:beta && bun run templates:release:beta",
		"all:release:major": "bun run components:release:major && bun run server:release:major && bun run shared:release:major && bun run templates:release:major",
		"all:release:minor": "bun run components:release:minor && bun run server:release:minor && bun run shared:release:minor && bun run templates:release:minor",
		"all:release:patch": "bun run components:release:patch && bun run server:release:patch && bun run shared:release:patch && bun run templates:release:patch",
		"all:test": "bun run server:test && bun run shared:test",
		"all:typecheck": "bun run components:typecheck && bun run server:typecheck && bun run shared:typecheck && bun run templates:typecheck",
		"biome:format": "biome format --write .",
		"biome:check": "biome check . --max-diagnostics=10000",
		"biome:check:ci": "biome check .",
		"components:audit": "cd packages/components && bun run audit",
		"components:build": "cd packages/components && bun run build",
		"components:publish:beta": "cd packages/components && bun run publish:beta",
		"components:release:beta": "cd packages/components && bun run release:beta",
		"components:release:major": "cd packages/components && bun run release:major",
		"components:release:minor": "cd packages/components && bun run release:minor",
		"components:release:patch": "cd packages/components && bun run release:patch",
		"components:test": "cd packages/components && bun run test",
		"components:test:watch": "cd packages/components && bun run test:watch",
		"components:typecheck": "cd packages/components && bun run typecheck",
		"server:audit": "cd packages/server && bun run audit",
		"server:build": "cd packages/server && bun run build",
		"server:publish:beta": "cd packages/server && bun run publish:beta",
		"server:release:beta": "cd packages/server && bun run release:beta",
		"server:release:major": "cd packages/server && bun run release:major",
		"server:release:minor": "cd packages/server && bun run release:minor",
		"server:release:patch": "cd packages/server && bun run release:patch",
		"server:test": "cd packages/server && bun run test",
		"server:test:watch": "cd packages/server && bun run test:watch",
		"server:typecheck": "cd packages/server && bun run typecheck",
		"shared:audit": "cd packages/shared && bun run audit",
		"shared:build": "cd packages/shared && bun run build",
		"shared:publish:beta": "cd packages/shared && bun run publish:beta",
		"shared:release:beta": "cd packages/shared && bun run release:beta",
		"shared:release:major": "cd packages/shared && bun run release:major",
		"shared:release:minor": "cd packages/shared && bun run release:minor",
		"shared:release:patch": "cd packages/shared && bun run release:patch",
		"shared:test": "cd packages/shared && bun run test",
		"shared:test:watch": "cd packages/shared && bun run test:watch",
		"shared:typecheck": "cd packages/shared && bun run typecheck",
		"templates:audit": "cd packages/templates && bun run audit",
		"templates:build": "cd packages/templates && bun run build",
		"templates:publish:beta": "cd packages/templates && bun run publish:beta",
		"templates:release:beta": "cd packages/templates && bun run release:beta",
		"templates:release:major": "cd packages/templates && bun run release:major",
		"templates:release:minor": "cd packages/templates && bun run release:minor",
		"templates:release:patch": "cd packages/templates && bun run release:patch",
		"templates:test": "cd packages/templates && bun run test",
		"templates:test:watch": "cd packages/templates && bun run test:watch",
		"templates:typecheck": "cd packages/templates && bun run typecheck"
	},
	"type": "module",
	"workspaces": [
		"packages/*"
	]
}
