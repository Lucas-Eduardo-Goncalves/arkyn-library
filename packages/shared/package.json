{
	"name": "@arkyn/shared",
	"version": "3.0.1-beta.172",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"type": "module",
	"types": "./dist/index.d.ts",
	"license": "Apache-2.0",
	"author": "Arkyn | Lucas Gonçalves",
	"description": "Comprehensive collection of reusable utilities for data formatting, validation, generation, and manipulation, featuring Brazilian document validators and financial tools.",
	"keywords": [
		"utilities",
		"formatting",
		"brazilian-documents",
		"cpf",
		"cnpj",
		"cep",
		"currency",
		"typescript",
		"generators"
	],
	"engines": {
		"node": ">=24.16.0",
		"bun": ">=1.3.14"
	},
	"homepage": "https://docs.arkyn.dev/en/shared/introduction",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Lucas-Eduardo-Goncalves/arkyn-library.git",
		"directory": "packages/components"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE.txt"
	],
	"sideEffects": false,
	"scripts": {
		"audit": "bun audit --workspace packages/shared",
		"build": "bunx vite build && bunx tsc --project tsconfig.json --emitDeclarationOnly && bun ./generate-exports.ts",
		"prebuild": "rm -rf dist",
		"publish:beta": "npm publish --tag beta",
		"publish:latest": "npm publish --tag latest",
		"release:beta": "bun ./generate-version.ts beta",
		"release:patch": "bun ./generate-version.ts patch",
		"release:minor": "bun ./generate-version.ts minor",
		"release:major": "bun ./generate-version.ts major",
		"test": "bunx vitest --config vitest.config.ts --run",
		"test:watch": "bunx vitest --config vitest.config.ts --watch",
		"typecheck": "bunx tsc --project tsconfig.json --noEmit"
	},
	"dependencies": {},
	"peerDependencies": {
		"libphonenumber-js": ">=1.13.7"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"@types/node": "catalog:",
		"libphonenumber-js": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:"
	},
