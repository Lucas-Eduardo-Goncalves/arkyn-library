{
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": [
		"node_modules",
		"dist",
		"documentation/**/*",
		"vite.config.ts",
		"vitest.config.ts",
		"**/*.config.ts",
		"**/*.test.ts",
		"**/*.test.tsx",
		"**/*.spec.ts",
		"**/*.spec.tsx"
	],
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"composite": false,
		"declaration": true,
		"declarationDir": "./dist",
		"declarationMap": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"inlineSources": false,
		"isolatedModules": true,
		"moduleResolution": "bundler",
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"preserveWatchOutput": true,
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"types": ["node"],
		"module": "ESNext",
		"target": "ESNext"
	}
}
